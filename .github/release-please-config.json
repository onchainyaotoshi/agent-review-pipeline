{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-search-depth": 10,
  "commit-search-depth": 30,
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "agent-review-pipeline",
      "extra-files": [
        {
          "type": "json",
          "path": "plugins/agent-review-pipeline/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[0].version"
        },
        "plugins/agent-review-pipeline/skills/arp/SKILL.md"
      ]
    }
  }
}
